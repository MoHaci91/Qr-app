{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A restaurant menu item with a 3D model",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "description": { "type": "string", "description": "Product description" },
        "modelUrl": { "type": "string", "description": "URL to the GLB/GLTF model" },
        "imageUrl": { "type": "string", "description": "URL to the thumbnail image" },
        "qrCodeUrl": { "type": "string", "description": "URL to the generated QR code image" },
        "scanCount": { "type": "number", "description": "Total number of scans" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "price", "modelUrl"]
    },
    "Scan": {
      "title": "Scan",
      "description": "A record of a product being scanned",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the scanned product" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time of scan" },
        "userAgent": { "type": "string", "description": "User agent of the device" }
      },
      "required": ["productId", "timestamp"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of menu products"
    },
    "/products/{productId}/scans/{scanId}": {
      "schema": "Scan",
      "description": "Individual scan events for a product"
    }
  }
}
